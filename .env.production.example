# =====================================================================
# Konfigurasi PRODUKSI (Hostinger). Salin menjadi .env di server:
#   cp .env.production.example .env
# lalu isi nilai DB_* dan APP_URL, kemudian jalankan:
#   php artisan key:generate
# JANGAN commit file .env ke git dan jangan upload .env lokal ke server.
# =====================================================================

APP_NAME="InPULS KEMENKES"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://domain-anda.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# Log seminimal mungkin di produksi
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Database MySQL (buat di hPanel > Databases > MySQL Databases) ---
# Nama DB & user Hostinger biasanya berawalan uXXXXXXXX_
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=uXXXXXXXX_labkesmas
DB_USERNAME=uXXXXXXXX_admin
DB_PASSWORD=ISI_PASSWORD_DB

# Session & cache berbasis database (tabelnya dibuat oleh migrate).
# SESSION_SECURE_COOKIE=true karena domain memakai HTTPS.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database

# Email opsional (default aman: tulis ke log). Isi SMTP Hostinger bila perlu kirim email.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@domain-anda.com"
MAIL_FROM_NAME="${APP_NAME}"

# Vite: aset di-build lokal (npm run build) dan diupload sebagai public/build.
VITE_APP_NAME="${APP_NAME}"
